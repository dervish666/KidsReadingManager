# Authentication (one of these is required)
JWT_SECRET=                    # Enables multi-tenant JWT auth (recommended)
WORKER_ADMIN_PASSWORD=         # Legacy shared password auth (deprecated)

# MyLogin SSO (optional, for school SSO)
MYLOGIN_CLIENT_ID=
MYLOGIN_CLIENT_SECRET=
MYLOGIN_REDIRECT_URI=          # e.g. https://tallyreading.uk/api/auth/mylogin/callback

# AI Recommendations (optional, configure at least one for AI features)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:3001

# Email (optional)
EMAIL_FROM=
SUPPORT_EMAIL=                 # Falls back to EMAIL_FROM

# Wonde Integration (optional)
WONDE_WEBHOOK_SECRET=

# Encryption (optional, recommended — falls back to JWT_SECRET)
ENCRYPTION_KEY=                # Separate AES-GCM key for encrypting sensitive data (Wonde tokens, API keys)

# Sentry (optional)
SENTRY_DSN=                    # Error tracking DSN

# Stripe Billing (optional, required for subscription features)
STRIPE_SECRET_KEY=             # Set via `wrangler secret put`
STRIPE_WEBHOOK_SECRET=         # Set via `wrangler secret put`
STRIPE_ANNUAL_PRICE_ID=        # Annual plan Stripe Price ID
STRIPE_AI_ADDON_PRICE_ID=      # AI add-on Stripe Price ID

# Email provider (optional, for transactional email via Resend)
RESEND_API_KEY=                # Resend API key (fallback to Cloudflare Email Routing)

# Local Development
STORAGE_TYPE=json              # Use 'json' for local file storage, 'd1' for database
