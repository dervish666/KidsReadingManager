{
  "name": "tally-reading",
  "version": "3.73.0",
  "description": "Cloudflare Workers implementation of Tally Reading API",
  "main": "src/index.js",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "start": "rsbuild dev",
    "go": "npm run build && npx wrangler d1 migrations apply reading-manager-db --remote && npm run deploy",
    "start:dev": "concurrently -n worker,frontend -c blue,green \"npm run dev\" \"npm run start\"",
    "seed:local": "node scripts/seed-local.js",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "migrate": "node scripts/migration.js",
    "build": "rsbuild build",
    "build:deploy": "./scripts/build-and-deploy.sh",
    "build:deploy:dev": "./scripts/build-and-deploy.sh dev",
    "test": "vitest run",
    "test:e2e": "npx playwright test --config=e2e/playwright.config.js",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "analyze": "BUNDLE_ANALYZE=true rsbuild build",
    "dev:debug": "node --inspect node_modules/.bin/wrangler dev"
  },
  "author": "",
  "license": "CC BY-NC 4.0",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.96.0",
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "7.0.2",
    "@mui/material": "7.0.2",
    "@sentry/cloudflare": "^10.45.0",
    "@sentry/react": "^10.45.0",
    "hono": "^4.12.12",
    "html5-qrcode": "^2.3.8",
    "jspdf": "^4.2.1",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-joyride": "^3.0.0",
    "stripe": "^22.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@rsbuild/core": "^2.0.6",
    "@rsbuild/plugin-react": "^2.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/coverage-v8": "^4.0.16",
    "concurrently": "^9.2.1",
    "dotenv": "^17.3.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "happy-dom": "^20.0.11",
    "node-fetch": "^3.3.2",
    "prettier": "^3.8.1",
    "uuid": "^14.0.0",
    "vite": "^7.3.3",
    "vitest": "^4.0.16",
    "wrangler": "^4.92.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
