{
  "name": "tally-reading",
  "version": "3.25.0",
  "description": "Cloudflare Workers implementation of Tally Reading API",
  "main": "src/index.js",
  "scripts": {
    "start": "rsbuild dev",
    "go": "npm run build && npx wrangler d1 migrations apply reading-manager-db --remote && npm run deploy",
    "start:dev": "npm run dev & npm run start",
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "migrate": "node scripts/migration.js",
    "build": "rsbuild build",
    "build:deploy": "./scripts/build-and-deploy.sh",
    "build:deploy:dev": "./scripts/build-and-deploy.sh dev",
    "test": "vitest run",
    "test:e2e": "npx playwright test --config=e2e/playwright.config.js",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "author": "",
  "license": "CC BY-NC 4.0",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.61.0",
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@mui/icons-material": "7.0.2",
    "@mui/material": "7.0.2",
    "@sentry/cloudflare": "^10.45.0",
    "@sentry/react": "^10.45.0",
    "hono": "^4.7.7",
    "html5-qrcode": "^2.3.8",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "stripe": "^20.4.1",
    "uuid": "11.1.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@rsbuild/core": "^1.3.9",
    "@rsbuild/plugin-react": "^1.2.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.16",
    "dotenv": "^17.3.1",
    "happy-dom": "^20.0.11",
    "prettier": "^3.8.1",
    "vitest": "^4.0.16",
    "wrangler": "^4.77.0"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "overrides": {
    "esbuild": "0.25.2",
    "undici": "7.24.4"
  }
}
